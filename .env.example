# Tolino Hacks Configuration
# Copy this file to .env and fill in your values.
# Place on device at /mnt/onboard/.adds/.env before applying update.tar.

# --- SSH ---
# Password is auto-generated on first SSH Start (stored in .adds/.ssh_password)
# To use key auth instead, place your public key as .adds/authorized_keys

# --- Reverse SSH tunnel (cloud-connect.sh, optional) ---
TUNNEL_USER=user
TUNNEL_HOST=yourserver.com
TUNNEL_PORT=2223
TUNNEL_KEY=/mnt/onboard/.adds/tolino_client_key

# --- MCP Server (hosted on your server) ---
MCP_CLIENT_ID=your_client_id
MCP_CLIENT_SECRET=your_secret
MCP_AUTH_TOKEN=your_token
MCP_SSH_KEY=~/.ssh/id_ed25519
MCP_TUNNEL_PORT=2223
